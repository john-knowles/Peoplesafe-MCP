{
  "name": "peoplesafe-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for Peoplesafe User Management APIs in the staging environment.",
  "type": "module",
  "main": "dist/functionApp.js",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "generate": "node ./scripts/generate-openapi-artifacts.mjs",
    "build": "npm run generate && tsc --project tsconfig.json",
    "dev": "npm run generate && tsx watch src/index.ts",
    "dev:inspect": "npx -y @modelcontextprotocol/inspector node dist/index.js",
    "start": "node ./dist/index.js",
    "deploy": "node ./scripts/deploy-azure.mjs"
  },
  "dependencies": {
    "@azure/functions": "^4.13.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.16.8",
    "@types/node": "^22.15.30",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}

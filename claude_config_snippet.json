{
  "mcpServers": {
    "peoplesafe-staging": {
      "command": "npx",
      "args": [
        "-y",
        "tsx",
        "/path/to/peoplesafe-mcp/src/index.ts"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "PEOPLESAFE_AUTH_TOKEN": "",
        "PEOPLESAFE_SUBSCRIPTION_KEY": ""
      }
    }
  }
}
